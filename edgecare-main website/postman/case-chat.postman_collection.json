{
  "info": {
    "name": "EdgeCare Case Chat",
    "_postman_id": "d4df1b20-0000-4c00-a000-chatcase",
    "description": "Case chat REST endpoints for EdgeCare",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Chat Messages",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/cases/{{caseId}}/chat/messages?limit=30",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "cases", "{{caseId}}", "chat", "messages"],
          "query": [{ "key": "limit", "value": "30" }]
        }
      }
    },
    {
      "name": "Send Chat Message",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"content\": \"Hello from Postman\",\n  \"type\": \"TEXT\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/cases/{{caseId}}/chat/messages",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "cases", "{{caseId}}", "chat", "messages"]
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "https://edgecare.onrender.com" },
    { "key": "caseId", "value": "1" },
    { "key": "accessToken", "value": "" }
  ]
}
