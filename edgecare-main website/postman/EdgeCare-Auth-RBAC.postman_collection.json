    {
      "name": "Cases",
      "item": [
        {
          "name": "Create Case (Patient)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Severe rash on hand\",\n  \"duration\": \"3 days\",\n  \"medications\": \"Cetirizine\",\n  \"isEmergency\": false,\n  \"description\": \"Red itchy patches since 3 days\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/cases",
              "host": [
