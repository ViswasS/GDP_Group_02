    {
      "name": "Refresh Token Flow",
      "item": [
        {
          "name": "Refresh Patient Token",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set(\"oldPatientRefreshToken\", pm.environment.get(\"patientRefreshToken\"));"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "const data = json.data || {};",
                  "const newAccess = data.accessToken || data.token || json.accessToken;",
                  "const newRefresh = data.refreshToken || json.refreshToken;",
                  "pm.test(\"New access token present\", () => !!newAccess);",
                  "pm.environment.set(\"patientToken\", newAccess);",
                  "pm.environment.set(\"lastAccessToken\", newAccess);",
                  "pm.test(\"New refresh token present\", () => !!newRefresh);",
                  "pm.environment.set(\"patientRefreshToken\", newRefresh);",
                  "const old = pm.environment.get(\"oldPatientRefreshToken\");",
                  "if (old) pm.test(\"Refresh token rotated\", () => newRefresh !== old);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{patientRefreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "refresh"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Refresh Patient Token with OLD token (expect 401)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{oldPatientRefreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "refresh"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 401 or 403\", () => [401,403].includes(pm.response.code));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Refresh Doctor Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{doctorRefreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "refresh"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "const data = json.data || {};",
                  "const newAccess = data.accessToken || data.token || json.accessToken;",
                  "const newRefresh = data.refreshToken || json.refreshToken;",
                  "pm.environment.set(\"doctorToken\", newAccess);",
                  "if (newRefresh) pm.environment.set(\"doctorRefreshToken\", newRefresh);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Logout Patient (revoke refresh)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set(\"logoutPatientRefreshToken\", pm.environment.get(\"patientRefreshToken\"));"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test(\"Success flag true\", () => json.success === true);",
                  "pm.environment.unset(\"patientRefreshToken\");"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{patientRefreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "logout"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Refresh after Logout (expect fail)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{logoutPatientRefreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "refresh"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 401 or 403\", () => [401,403].includes(pm.response.code));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
