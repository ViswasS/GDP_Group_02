              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 201',()=>pm.expect([200,201]).to.include(pm.response.code));",
                  "const j = pm.response.json();",
                  "const id = j?.data?.id ?? j?.data?.case?.id ?? j?.data?.triageCase?.id ?? j?.case?.id ?? j?.triageCase?.id ?? j?.caseId;",
                  "pm.expect(id,'caseId missing').to.exist;",
                  "pm.environment.set('caseId', String(id));"
