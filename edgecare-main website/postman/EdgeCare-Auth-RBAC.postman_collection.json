          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test(\"Success flag true\", () => json.success === true);",
                  "const data = json.data || {};",
                  "const access = data.accessToken || data.token || (data.data && data.data.accessToken) || json.accessToken;",
                  "const refresh = data.refreshToken || (data.data && data.data.refreshToken) || json.refreshToken;",
                  "pm.test(\"Access token present\", () => !!access);",
                  "pm.environment.set(\"patientToken\", access);",
                  "pm.environment.set(\"lastAccessToken\", access);",
                  "if (refresh) pm.environment.set(\"patientRefreshToken\", refresh); else pm.test(\"Refresh token present\", () => false);"
                ],
                "type": "text/javascript"
              }
            }
